# Rust build artifacts
src-tauri/target/

# Bundled sidecar binaries — staged by scripts/setup.sh (dev) or CI
# (release), never committed (large + platform-specific). Wildcard
# covers both `deno-<triple>` (real sidecar) and any other staged
# binary names a future setup script might produce.
src-tauri/binaries/deno-*
# Defensive: an earlier version of setup.ps1 staged the daemon-runner
# here too. The current setup.ps1 cleans it up, but a contributor
# running an older script (or manually placing a binary) shouldn't
# accidentally commit it. The runner is built from
# src/bin/psycheros-daemon-runner.rs and Tauri auto-bundles the
# target/release/ output.
src-tauri/binaries/psycheros-daemon-runner-*

# Mobile and Windows-tile icons that `tauri icon` regenerates alongside the
# desktop ones — not used by the desktop launcher and noisy in diffs. The
# desktop icons (32x32.png, 128x128.png, 128x128@2x.png, icon.png, icon.icns,
# icon.ico) ARE committed; see src-tauri/icons/README.md for how to regenerate.
src-tauri/icons/android/
src-tauri/icons/ios/
src-tauri/icons/Square*Logo.png
src-tauri/icons/StoreLogo.png
src-tauri/icons/64x64.png
src-tauri/icons/source.png

# Tauri-generated schema files
src-tauri/gen/

# Node modules if any frontend tooling is added later
node_modules/

# OS / editor noise
.DS_Store
*.swp
