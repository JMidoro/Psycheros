# Rust build artifacts
src-tauri/target/

# Bundled Deno sidecars — staged by scripts/setup.sh (dev) or CI (release),
# never committed (large + platform-specific binaries).
src-tauri/binaries/deno-*

# Mobile and Windows-tile icons that `tauri icon` regenerates alongside the
# desktop ones — not used by the desktop launcher and noisy in diffs. The
# desktop icons (32x32.png, 128x128.png, 128x128@2x.png, icon.png, icon.icns,
# icon.ico) ARE committed; see src-tauri/icons/README.md for how to regenerate.
src-tauri/icons/android/
src-tauri/icons/ios/
src-tauri/icons/Square*Logo.png
src-tauri/icons/StoreLogo.png
src-tauri/icons/64x64.png
src-tauri/icons/source.png

# Tauri-generated schema files
src-tauri/gen/

# Node modules if any frontend tooling is added later
node_modules/

# OS / editor noise
.DS_Store
*.swp
